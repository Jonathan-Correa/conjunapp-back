# ConjunApp API
#
# Copia a .env y ajusta valores. Ver docs/VariablesEntorno.md

APP_NAME=ConjunApp API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://postgres:root@localhost:5432/conjunapp
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
ALLOW_ADMIN_REGISTER=true
SEED_ON_STARTUP=true
